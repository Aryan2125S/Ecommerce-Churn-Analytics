# ============================================================
# Environment Configuration
# Enterprise E-Commerce Customer Churn Analytics Platform
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.
# ============================================================

# --- Database Configuration ---
DB_ENGINE=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce_churn
DB_USER=root
DB_PASSWORD=your_password_here

# --- Application Settings ---
APP_ENV=development
APP_DEBUG=True
APP_LOG_LEVEL=INFO
LOG_DIR=logs

# --- Model Configuration ---
MODEL_DIR=models/export
BEST_MODEL_NAME=best_churn_model.joblib
RANDOM_STATE=42
TEST_SIZE=0.2
CV_FOLDS=5

# --- Data Paths ---
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
EXTERNAL_DATA_DIR=data/external

# --- Data Generation ---
DATASET_SIZE=50000

# --- Streamlit Settings ---
STREAMLIT_THEME=light
STREAMLIT_PORT=8501
