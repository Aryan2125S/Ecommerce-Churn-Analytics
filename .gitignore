# ==========================================================================
# Byte-compiled / optimized / DLL files
# ==========================================================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================================================
# Distribution / packaging
# ==========================================================================
dist/
build/
*.egg-info/
*.egg

# ==========================================================================
# Virtual environments
# ==========================================================================
venv/
env/
.venv/
.env

# ==========================================================================
# IDE / Editor settings
# ==========================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ==========================================================================
# OS-generated files
# ==========================================================================
.DS_Store
Thumbs.db
desktop.ini

# ==========================================================================
# Logs
# ==========================================================================
logs/*.log
!logs/.gitkeep

# ==========================================================================
# Serialized model artifacts
# ==========================================================================
models/export/*.joblib
models/export/*.pkl
models/export/*.h5
!models/export/.gitkeep

# ==========================================================================
# Data files (keep structure, ignore large files)
# ==========================================================================
data/raw/*.csv
data/processed/*.csv
!data/processed/powerbi_export.csv
data/external/*.csv
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# ==========================================================================
# Generated reports and assets
# ==========================================================================
reports/assets/*.png
reports/assets/*.jpg
reports/assets/*.svg
reports/*.pptx
reports/*.pdf
!reports/assets/.gitkeep

# ==========================================================================
# Jupyter Notebook checkpoints
# ==========================================================================
.ipynb_checkpoints/
notebooks/*.ipynb
!notebooks/.gitkeep

# ==========================================================================
# Database files
# ==========================================================================
*.db
*.sqlite3

# ==========================================================================
# Streamlit
# ==========================================================================
.streamlit/secrets.toml

# ==========================================================================
# Miscellaneous
# ==========================================================================
*.bak
*.tmp
*.temp
.coverage
htmlcov/
